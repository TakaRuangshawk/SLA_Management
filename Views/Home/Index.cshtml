<style>
    #banner-fv{
        background-color: #225789;
        color: white;
        font-size: 20px;
        border-radius: 15px;
        margin-top: 15px;
        
    }

    #banner-so {
        background-color: #027913;
        color: white;
        font-size: 20px;
        border-radius: 15px;
    }
    #comlogbox {
        text-align: center;
        display: flex !important;
        justify-content: center;
        align-items: flex-start;
        padding-left: 10px;
        font-weight: 700;
        border-radius: 15px 15px 15px 15px;
        background-color: rgb(255,255,255);
        color: black;
        flex-wrap: wrap;
        font-size: 35px;
        height: 75px;
        align-content: center;
        border-style: ridge;
        border-color:gray;
        border:outset;
    }
    .ds-flex-center{
        display:flex;
        justify-content:center;
    }
    .ds-flex-spacearound{
        display:flex;
        justify-content:space-around;
    }
    .row{
        margin:auto;
    }
    table{
        background-color:white;    
    }

    .custom-table-home thead tr, .custom-table thead th {
        border-top: none;
        border-bottom: none !important;
        color: #000;
        background-color: #8fcaf4;
        font-size: 1vw;
        border-color: antiquewhite;
        border: 3px solid lightgray;
    }

    .custom-table-home tbody th, .custom-table tbody td {
        color: black;
        padding-bottom: 20px;
        padding-top: 20px;
        font-weight: 300;
        transition: .3s all ease;
        border: 2px solid lightgray;
    }
    @@media (max-width: 1199px) {
        #row-pic-welcome {
            display: none;
        }
    }
    @@media (min-width: 1200px) { 
        #row-pic-welcome{
            height: auto;
            display: flex;
            align-content: center;
            justify-content: flex-end;
        }

        .sla-tracking-row{
            padding-left:130px;
        }

        #maincard-comlog{
            margin-left:130px
        }
    }

    /* EJLog History 7 Days Chart */
    .ejlog-chart-card {
        margin-top: 15px;
        margin-bottom: 15px;
        padding: 16px 18px 12px;
        background-color: rgba(255,255,255,1);
        border-radius: 15px;
        border: outset;
        border-color: lightgray;
        color: #000;
    }


    .ejlog-chart-legend {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 28px;
        margin-bottom: 8px;
        font-size: 1rem;
        font-weight: 600;
    }

    .ejlog-chart-legend span {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    }

    .ejlog-chart-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        display: inline-block;
    }

    .ejlog-pink { background-color: #df67bd; }
    .ejlog-rose { background-color: #e36880; }
    .ejlog-brown { background-color: #c0644c; }

    .ejlog-chart-area {
        display: flex;
        height: 260px;
    }

    .ejlog-y-axis {
        width: 38px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-end;
        padding-right: 8px;
        padding-bottom: 34px;
        font-size: 0.85rem;
        color: #111;
        box-sizing: border-box;
    }

    .ejlog-plot {
        position: relative;
        flex: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 8px;
        padding-bottom: 34px;
        overflow-x: auto;
    }

    .ejlog-grid {
        position: absolute;
        inset: 0 0 34px 0;
        background: repeating-linear-gradient(
            to bottom,
            transparent 0,
            transparent calc(25% - 1px),
            #d9d9d9 calc(25% - 1px),
            #d9d9d9 25%
        );
        border-top: 1px solid #ededed;
        pointer-events: none;
    }

    .ejlog-group {
        position: relative;
        z-index: 1;
        height: 100%;
        min-width: 74px;
        flex: 1;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        gap: 2px;
    }

    .ejlog-group-label {
        position: absolute;
        bottom: -27px;
        left: 50%;
        transform: translateX(-50%);
        margin: 0;
        font-size: 0.82rem;
        white-space: nowrap;
        color: #000;
    }

    .ejlog-bar {
        width: 22px;
        height: 0%;
        min-height: 3px;
        border-radius: 6px 6px 0 0;
        position: relative;
        transition: height .25s ease;
    }

    .ejlog-bar-zero {
        min-height: 0;
        height: 0 !important;
    }

    .ejlog-bar-value {
        position: absolute;
        top: 5px;
        left: 50%;
        transform: translateX(-50%);
        color: #fff;
        font-size: 0.8rem;
        line-height: 1;
        font-weight: 700;
        display: none;
    }

    .ejlog-bar.outside-value .ejlog-bar-value {
        top: -18px;
        color: #000;
    }

    .ejlog-loading,
    .ejlog-error {
        height: 260px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #555;
        font-weight: 600;
    }

    @@media (max-width: 575px) {

        .ejlog-chart-legend {
            gap: 16px;
            font-size: 0.9rem;
        }

        .ejlog-group {
            min-width: 68px;
        }

        .ejlog-bar {
            width: 19px;
        }
    }

</style>

